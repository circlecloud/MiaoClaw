{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "MiaoClaw",
  "version": "0.1.0",
  "identifier": "com.miaoclaw.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "pet",
        "title": "MiaoClaw",
        "width": 256,
        "height": 256,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "url": "index.html"
      },
      {
        "label": "chat",
        "title": "MiaoClaw Chat",
        "width": 400,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "url": "index.html#/chat"
      },
      {
        "label": "settings",
        "title": "MiaoClaw Settings",
        "width": 640,
        "height": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "url": "index.html#/settings"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "MiaoClaw - 你的桌面宠物助理"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": { "open": true },
    "sql": { "preload": { "db": "sqlite:miaoclaw.db" } },
    "autostart": null,
    "global-shortcut": null
  }
}
